# GitHub Configuration
GITHUB_TOKEN=ghp_your_personal_access_token_here
GITHUB_USERNAME=your_github_username
GITHUB_REPO_OWNER=open-metadata
GITHUB_REPO_NAME=OpenMetadata

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Resend Email Configuration
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_TO_EMAIL=you@youremail.com

# CRON Schedule (default: every minute)
CRON_SCHEDULE=* * * * *

# Optional: Delay between actions in ms (to avoid rate limits)
ACTION_DELAY_MS=2000

# Live log dashboard port
PORT=3000

# Auto-comment mode:
#   yes → bot posts the AI-generated comment on GitHub automatically
#   no  → bot only emails you with issue details + suggested comment to paste yourself
AUTO_COMMENT=no
